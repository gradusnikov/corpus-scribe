{
  "manifest_version": 2,
  "name": "Corpus Scribe",
  "version": "0.1.0",
  "description": "Send Zotero items (PDF attachments + notes) to a Corpus Scribe backend.",
  "author": "Wojciech Gradkowski",
  "applications": {
    "zotero": {
      "id": "corpus-scribe@wgradkowski",
      "update_url": "https://raw.githubusercontent.com/wgradkowski/send-to-scribe/main/zotero-plugin/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "9.0.*"
    }
  }
}
